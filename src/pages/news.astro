---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const sortedNews = allNews.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});
---

<Layout
  title="News | BBHMM Stake Pool"
  description="Latest news and updates from the BBHMM Cardano stake pool."
>
  <div class="page-header">
    <div class="container">
      <h1>News & Updates</h1>
      <p>Stay up to date with the latest from BBHMM</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="news-grid">
        {sortedNews.map((post) => (
          <article class="news-card animate-in">
            <div class="news-card-body">
              <div class="news-card-date">
                {new Date(post.data.date).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </div>
              <h3>
                <a href={`/news/${post.id}/`}>{post.data.title}</a>
              </h3>
              <p>{post.data.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
